{
  "name": "frost-threshold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "deploy": "npm run build && gh-pages -d dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "wasm": "PATH=$HOME/.cargo/bin:$PATH wasm-pack build crate --target web --out-dir ../pkg"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "autoprefixer": "^10.4.21",
    "gh-pages": "^6.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
